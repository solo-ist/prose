{
  "permissions": {
    "deny": [
      "Read(.env)",
      "Read(.env.sentry-build-plugin)",
      "Read(.mcp.json)",
      "Read(build/*.provisionprofile)",
      "Edit(.env)",
      "Edit(.env.sentry-build-plugin)",
      "Edit(.mcp.json)"
    ],
    "allow": [
      "Bash(npm run *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(lsof *)",
      "Bash(kill *)",
      "Bash(pkill *)",
      "Bash(cat .dev.pid*)",
      "Bash(ps *)",
      "Bash(sleep *)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(gh issue *)",
      "Bash(gh pr *)",
      "Bash(gh project *)",
      "Bash(gh run *)",
      "Bash(gh api *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/doc-check.sh"
          }
        ]
      }
    ]
  }
}
