# reMarkable OCR Service Configuration
# These environment variables enable handwriting recognition for reMarkable notebooks

# Lambda endpoint for the OCR service
REMARKABLE_OCR_URL=https://your-lambda-url.lambda-url.us-east-1.on.aws/

# API key for authentication (get from service provider)
REMARKABLE_OCR_API_KEY=your-api-key-here

# Google Docs Sync
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Application type: Desktop app
# Enable APIs: Google Drive API, Google People API (for profile info)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret

# Sentry Error Tracking
# Auth token for source map upload (optional, only needed for production builds)
SENTRY_AUTH_TOKEN=
