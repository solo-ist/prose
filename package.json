{
  "name": "prose",
  "version": "1.0.0",
  "description": "A minimal markdown editor with AI chat",
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "npm run build:preload && electron-vite dev",
    "dev:kill": "kill $(cat .dev.pid 2>/dev/null) 2>/dev/null || true; lsof -ti:9222 | xargs kill -9 2>/dev/null || true; lsof -ti:5173 | xargs kill -9 2>/dev/null || true",
    "dev:restart": "npm run dev:kill && sleep 2 && npm run dev",
    "build:env": "node -e \"require('fs').writeFileSync('src/main/env.ts', '// Auto-generated — do not edit\\nexport const IS_MAS_BUILD = ' + (process.env.MAS_BUILD === '1') + '\\n')\"",
    "build": "npm run build:env && npm run build:mcp-stdio && electron-vite build && npm run build:preload",
    "build:preload": "npx esbuild src/preload/index.ts --bundle --platform=node --format=cjs --target=node18 --outfile=out/preload-cjs/index.cjs --external:electron",
    "build:mcp-stdio": "npx esbuild src/mcp-stdio/index.ts --bundle --platform=node --target=node18 --outfile=out/mcp-stdio.js",
    "preview": "electron-vite preview",
    "postinstall": "electron-builder install-app-deps",
    "build:mac": "npm run build && electron-builder --mac",
    "build:mas": "MAS_BUILD=1 npm run build && electron-builder --mac mas",
    "build:win": "npm run build && electron-builder --win",
    "build:linux": "npm run build && electron-builder --linux",
    "dev:web": "vite --config vite.web.config.ts",
    "build:web": "vite build --config vite.web.config.ts",
    "preview:web": "vite preview --config vite.web.config.ts --open",
    "test:e2e": "npm run build && npx playwright test",
    "test:e2e:dev": "npx playwright test",
    "test:web": "npm run build:web && npx playwright test --config playwright.web.config.ts",
    "test:web:dev": "npx playwright test --config playwright.web.config.ts",
    "typecheck:e2e": "tsc --project tsconfig.e2e.json --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.1",
    "@anthropic-ai/sdk": "^0.39.0",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language-data": "^6.5.2",
    "@electron-toolkit/utils": "^3.0.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.4",
    "@radix-ui/react-label": "^2.1.1",
    "@radix-ui/react-scroll-area": "^1.2.2",
    "@radix-ui/react-select": "^2.1.4",
    "@radix-ui/react-separator": "^1.1.1",
    "@radix-ui/react-slot": "^1.1.1",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.2",
    "@radix-ui/react-tooltip": "^1.1.6",
    "@sentry/electron": "^7.10.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@tiptap/extension-image": "^2.27.2",
    "@tiptap/extension-link": "^2.27.1",
    "@tiptap/extension-placeholder": "^2.27.1",
    "@tiptap/extension-table": "^2.27.2",
    "@tiptap/extension-table-cell": "^2.27.2",
    "@tiptap/extension-table-header": "^2.27.2",
    "@tiptap/extension-table-row": "^2.27.2",
    "@tiptap/extension-underline": "^2.27.2",
    "@tiptap/pm": "^2.11.2",
    "@tiptap/react": "^2.11.2",
    "@tiptap/starter-kit": "^2.11.2",
    "@types/js-yaml": "^4.0.9",
    "ai": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "codemirror": "^6.0.2",
    "dotenv": "^17.2.3",
    "electron-updater": "^6.7.3",
    "framer-motion": "^12.25.0",
    "googleapis": "^144.0.0",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.468.0",
    "marked": "^17.0.1",
    "react-resizable-panels": "^2.1.7",
    "rmapi-js": "^9.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tiptap-markdown": "^0.8.10",
    "turndown": "^7.2.2",
    "zod-to-json-schema": "^3.25.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.0",
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^40.4.0",
    "electron-builder": "^26.8.1",
    "electron-playwright-helpers": "^2.1.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.3"
  },
  "overrides": {
    "minimatch": ">=10.2.3"
  }
}
